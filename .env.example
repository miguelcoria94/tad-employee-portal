# Copy this file to apps/web/.env.local and apps/api/.env.local
# and fill in the values from your Supabase project dashboard.

# ───────────────────────────────────────────────────────────────
# apps/api/.env.local
# ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
# Bind address. Leave unset (defaults to 0.0.0.0) for prod/containers.
# Set HOST=127.0.0.1 locally if startup fails on os.networkInterfaces().
HOST=127.0.0.1

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...                     # public; OK to ship
SUPABASE_SERVICE_ROLE_KEY=eyJ...             # backend only — never expose
# JWT signing keys are fetched at runtime from
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json — no shared secret needed
# (the API supports legacy HS256 and asymmetric ES256/RS256 keys).

# Postgres — runtime uses the TRANSACTION pooler (port 6543, with ?pgbouncer=true)
# Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Postgres — migrations use the SESSION pooler (port 5432). Drizzle's migrator
# needs session-mode because transaction-pooled connections can't hold a single
# session across multiple migration statements.
DIRECT_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:5173

# OpenAI — powers the "Ask Tad" assistant. Optional: if unset the assistant
# replies with a "not configured" message. Set this in your deploy provider
# (e.g. Railway) rather than committing it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email — optional. Training assignment ("email requests") and completion
# emails are sent through this. When EMAIL_PROVIDER is "log" (the default) the
# app logs emails to the server console instead of sending, so it boots and
# works without any provider. In-app notifications always fire regardless.
# To actually deliver email set EMAIL_PROVIDER=resend and a RESEND_API_KEY.
EMAIL_PROVIDER=log              # "log" (default) or "resend"
RESEND_API_KEY=                 # required only when EMAIL_PROVIDER=resend
EMAIL_FROM=TadHealth <onboarding@resend.dev>
# Absolute base URL used to build links inside emails (your web app origin).
APP_BASE_URL=http://localhost:5181

# ───────────────────────────────────────────────────────────────
# apps/web/.env.local
# ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=http://localhost:3001