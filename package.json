{
  "name": "tadhealth-employee-portal",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @tadhealth/web dev",
    "dev:api": "pnpm --filter @tadhealth/api dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @tadhealth/db generate",
    "db:migrate": "pnpm --filter @tadhealth/db migrate",
    "db:seed": "pnpm --filter @tadhealth/db seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}